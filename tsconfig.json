{
    "extends": "@tada5hi/tsconfig",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "noEmit": true,

        "noUncheckedIndexedAccess": false
    },
    "exclude": [
        "node_modules",
        "**/dist"
    ]
}
