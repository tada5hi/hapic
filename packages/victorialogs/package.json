{
    "name": "@hapic/victorialogs",
    "version": "2.0.1",
    "description": "A http client for victoria-logs.",
    "type": "module",
    "main": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist/"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build": "tsdown",
