    "keywords": [
        "grafana",
        "vl",
        "victorialogs",
        "aggregatrion"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tada5hi/hapic.git",
        "directory": "packages/victorialogs"
    },
    "bugs": {
        "url": "https://github.com/Tada5hi/hapic/issues"
    },
    "homepage": "https://github.com/Tada5hi/hapic#readme",
    "devDependencies": {
        "hapic": "^3.0.1"
    },
    "peerDependencies": {
        "hapic": "^3.0.1"
    },
    "publishConfig": {
        "access": "public"
